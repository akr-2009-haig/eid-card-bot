# ===================================================
# إعدادات بوت بطاقات العيد - متغيرات البيئة
# ===================================================
# انسخ هذا الملف إلى .env وعدّل القيم قبل تشغيل البوت

# رمز البوت - احصل عليه من @BotFather
BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# معرف API - احصل عليه من https://my.telegram.org
API_ID=12345678

# مفتاح API - احصل عليه من https://my.telegram.org
API_HASH=0123456789abcdef0123456789abcdef

# معرفات الأدمن مفصولة بفاصلة (يمكن إضافة أكثر من أدمن)
ADMIN_IDS=123456789,987654321

# ---------------------------------------------------
# إعدادات اختيارية - يمكن تركها فارغة لاستخدام القيم الافتراضية
# ---------------------------------------------------

# مجلد التخزين الدائم (مهم للاستضافة السحابية مثل Render)
# STORAGE_DIR=/var/data

# مسار قاعدة البيانات (افتراضي: database/bot.db داخل STORAGE_DIR)
# DATABASE_PATH=/var/data/database/bot.db

# مجلد القوالب (افتراضي: data/templates داخل STORAGE_DIR)
# TEMPLATES_DIR=/var/data/data/templates

# مجلد الخطوط (افتراضي: data/fonts داخل مجلد التطبيق)
# FONTS_DIR=/app/data/fonts

# مجلد البطاقات الناتجة (افتراضي: data/generated داخل STORAGE_DIR)
# GENERATED_DIR=/var/data/data/generated

# مسار ملف السجل (افتراضي: logs/bot.log داخل STORAGE_DIR)
# LOG_FILE=/var/data/logs/bot.log

# مسار ملف الخط (افتراضي: data/fonts/arabic.ttf)
# FONT_PATH=/app/data/fonts/arabic.ttf
